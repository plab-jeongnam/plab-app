<% if .UsePlabData %># 플랩 API 키를 여기에 입력해 주세요
# 대시보드 > API 키 메뉴에서 발급받을 수 있어요
PLAB_API_KEY=
PLAB_API_URL=https://vibe.techin.pe.kr
<% end %><% if .ResearchersOnly %>
# Google 로그인 (플랩 공용 OAuth - 자동 세팅됨!)
# 커스텀 OAuth 앱을 사용하고 싶다면 아래 값을 변경해 주세요
GOOGLE_CLIENT_ID=__PLAB_OAUTH_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__PLAB_OAUTH_CLIENT_SECRET__

# NextAuth 설정 (자동 생성됨 - 변경 불필요)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<% .ProjectName %>-nextauth-secret-<% .ProjectName %>
<% end %>
